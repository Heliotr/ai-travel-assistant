# ============================================
# 环境变量配置模板
# ============================================
# 请复制此文件为 .env 并填入实际值

# ---------- 开发配置 ----------
EMP_CONF_WHITE_LIST=['/', '^/static/.*', '^/assets.*', '/api/login', '/api/register', '/api/auth', '/api/workflow/mode', '/health', '/ready', '/docs', '/redoc', '/openapi.json', '^/docs/.*', '^/api/new_graph.*', '^/api/graph.*', '^/api/deep_agent.*', '^/api/unified.*']

# ---------- LLM API 配置 ----------
# OpenAI / 兼容 OpenAI 的 API
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# 智谱 AI
ZHIPU_API_KEY=your-zhipu-api-key-here

# DeepSeek (可选)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 本地私有化部署 (可选)
LOCAL_BASE_URL=http://localhost:6006/v1

# ---------- 数据库配置 ----------
# MySQL
# DATABASE_URL=mysql+pymysql://user:password@host:port/database
# SQLite
DATABASE_URL=sqlite:///./travel_new.sqlite

# ---------- JWT 配置 ----------
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# ---------- Tavily 搜索 (可选) ----------
TAVILY_API_KEY=your-tavily-api-key-here

# ---------- Anthropic (可选) ----------
ANTHROPIC_AUTH_TOKEN=your-anthropic-token-here
ANTHROPIC_BASE_URL=https://api.anthropic.com